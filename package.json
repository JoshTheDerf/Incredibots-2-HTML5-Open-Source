{
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "typecheck": "vue-tsc --noEmit",
        "check:core:imports": "scripts/check-core-purity.sh",
        "check:core:node": "node scripts/check-core-node.mjs",
        "check:core": "npm run check:core:imports && npm run check:core:node",
        "gate": "npm run typecheck ; npm run check:core"
    },
    "browserslist": [
        "last 1 chrome version"
    ],
    "dependencies": {
        "@nuxt/ui": "^4.9.0",
        "@pixi/sound": "^6.0.1",
        "@vitejs/plugin-vue": "^6.0.7",
        "iconv-lite": "^0.6.2",
        "pinia": "^3.0.4",
        "pixi-viewport": "^6.0.3",
        "pixi.js": "^8.0.0",
        "tailwindcss": "^4.3.2",
        "vue": "^3.5.39"
    },
    "devDependencies": {
        "typescript": "^5.7.0",
        "vite": "^8.1.2",
        "vite-plugin-node-polyfills": "^0.28.0",
        "vue-tsc": "^3.3.6"
    }
}
